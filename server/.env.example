# ================================================================
# Diario Pan - server configuration
#
# Copy this file to ".env" and fill in the real values.
# The real .env is ignored by git on purpose (it holds secrets).
# ================================================================

# Port the web server listens on. Most hosts set this for you
# automatically; 3000 is a fine default for local testing.
PORT=3000

# ----------------------------------------------------------------
# Admin access
# ----------------------------------------------------------------
# The password for diariopan.com/upload. Only the pastor's team
# and the site admin should know this. Make it long and random.
ADMIN_PASSWORD=change-me-to-something-long-and-secret

# Secret used to sign the admin session cookie. Any long random
# string works. Changing it logs every admin out (which is fine).
SESSION_SECRET=another-long-random-string-here

# ----------------------------------------------------------------
# Google Drive (where the videos actually live - your 2TB plan)
# ----------------------------------------------------------------
# These come from Google Cloud Console. Full step-by-step guide
# in docs/GOOGLE-DRIVE.md. Short version:
#   1. Create a project at console.cloud.google.com
#   2. Enable the "Google Drive API"
#   3. Create an OAuth Client ID (type: Desktop app)
#   4. Run: npm run get-google-token
#      -> it opens a browser, you log in with the Google account
#         that has the 2TB Drive, and it prints the refresh token.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=paste-the-refresh-token-here

# The ID of the Drive folder where videos will be stored.
# Open the folder in Drive; the ID is the last part of the URL:
# https://drive.google.com/drive/folders/<THIS_PART>
GOOGLE_DRIVE_FOLDER_ID=paste-folder-id-here

# ----------------------------------------------------------------
# App store links (used by the QR download page). Fill these in
# once the apps are published; placeholders are fine until then.
# ----------------------------------------------------------------
ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=com.diariopan.app
IOS_STORE_URL=https://apps.apple.com/app/diario-pan/id0000000000
