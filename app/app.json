{
  "expo": {
    "name": "Diario Pan",
    "slug": "diario-pan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5ede3"
    },
    "ios": {
      "bundleIdentifier": "com.diariopan.app",
      "supportsTablet": true,
      "entitlements": {
        "com.apple.developer.usernotifications.time-sensitive": true
      },
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "_comment": "Allows plain http:// so the TestFlight build can stream from a MacBook on local WiFi. Once fully on https (Namecheap + certbot), remove NSAppTransportSecurity for App Store release."
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.diariopan.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f5ede3"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#7c4a1e",
          "sounds": [
            "./assets/campana.wav"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-asset",
      "./plugins/withFmtFix.js"
    ],
    "extra": {
      "eas": {
        "projectId": "a2467deb-23c5-4316-bfa1-a24f570f23c0"
      }
    },
    "owner": "abispac",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a2467deb-23c5-4316-bfa1-a24f570f23c0"
    }
  }
}
